library(dplyr)
library(Seurat)
library(patchwork)
#featurescater for plots
plot1 <- FeatureScatter(pbmc, feature1 = "nCount_RNA", feature2 = "percent.mt")
#load the PBMC dataset
pbmc.data <- Read10X(data.dir= "C:/Users/aggel/Documents/datasets/single rna seq for R/pbmc3k_filtered_gene_bc_matrices/filtered_gene_bc_matrices/hg19/")
#initialize the seyrat object with the raw non-normalized data
pbmc <- CreateSeuratObject(counts = pbmc.data, project = "pbmc3k", min.cells = 3, min.features = 200)
pbmc
# few gene examination for the first 30 cells
pbmc.data[c("CD3D", "TCL1A", "MS4A1"), 1:30]
#matrix size
dense.size <- object.size(as.matrix(pbmc.data))
sparse.size <- object.size(pbmc.data)
dense.size/sparse.size
# the [[]] operator can add colums to object metadata and can be used for QC stats
pbmc[["percent.mt"]]<- PercentageFeatureSet(pbmc, pattern = "^MT-")
#show QC metrics for first 5 cells
head(pbmc@meta.data, 5)
plot2 <- FeatureScatter(pbmc, feature1 = "ncCount_RNA", feature2 = "nFeature_RNA")
plot2 <- FeatureScatter(pbmc, feature1 = "nCount_RNA", feature2 = "nFeature_RNA")
plot1 + plot2
plot1 + plot2
#filter
pbmc <- subset(pbmc, subset = nFeature_RNA>200 & nFeature_RNA< 2500 & percent.mt< 5)
pbmc
#normalization
pbmc <- NormalizeData(pbmc, normalization.method = "LogNormalize", scale.factor = 10000)
pbmc <- NormalizeData(pbmc)
#highly variable features in cells
pbmc <- FindVariableFeatures(pbmc,selection.method = "vst", nfeatures = 2000)
#ideantify the 10 most variable genes
top10 <- head(VariableFeatures(pbmc),10)
#plot variable (with and without labels)
plot1 <- VariableFeaturePlot(pbmc)
plot2 <-  LabelPoints(plot = plot1, points = top10, repel = TRUE)
plot1 + plot2
#scale data
all.genes <- rownames(pbmc)
pbmc <- ScaleData(pbmc, features = all.genes)
#remove unwanted variability
pbmc <- ScaleData(pbmc, vars.to.regress = "percent.mt")
# genes with correletion positive or negative
pbmc <- RunPCA(pbmc, features = VariableFeatures(object = pbmc))
#examine and visualize PCA results
print(pbmc[["pca"]], dims = 1:5, nfeatures = 5)
VizDimLoadings(pbmc, dims = 1:2, reduction = "pca")
DimPlot(pbmc, reduction = "pca")+ NoLegend()
#heatmap
DimHeatmap(pbmc, dims = 1, cells = 500, balanced = TRUE)
DimHeatmap(pbmc, dims = 1:15, cells = 500, balanced = TRUE)
#Elbowplot
ElbowPlot(pbmc)
#clustering
pbmc <- FindNeighbors(pbmc, dims = 1:10)
View(pbmc)
pbmc <- FindClusters(pbmc, resolution = 0.5)
head(Idents(pbmc), 5)
pbmc <- FindClusters(pbmc, resolution = 0.5)
head(Idents(pbmc), 5)
pbmc <- RunUMAP(pbmc, dims = 1:10)
#indivindual cluster
DimPlot(pbmc, reduction = "uumap")
#indivindual cluster
DimPlot(pbmc, reduction = "umap")
#find all markers of cluster 2
cluster2.markers <- FindAllMarkers(pbmc, ident.1=2)
head(cluster2.markers, n=2)
head(cluster2.markers, n=5)
head(cluster2.markers, n =5)
cluster2.markers <- FindAllMarkers(pbmc, ident.1 = 2)
head(cluster2.markers, n = 5)
cluster2.markers <- FindMarkers(pbmc, ident.1 = 2)
head(cluster2.markers, n = 5)
#find markers distinguishing cluster 5 from cluster 0 and 3
cluster5.markers <- FindMarkers(pbmc, ident.1 = 5, ident.2 = c(0, 3))
cluster5.markers <- FindMarkers(pbmc, ident.1 = 5, ident.2 = c(0, 3))
head(cluster5.markers, n = 5)
View(cluster2.markers)
pbmc.markers %>%
group_by(cluster) %>%
dplyr::filter(avg_log2FC>1)
#find positive markers for every cluster compared to all remaining cells
pbmc.markers <- FindAllMarkers(pbmc,only.pos = TRUE)
pbmc.markers <- FindAllMarkers(pbmc,only.pos = TRUE)
pbmc.markers %>%
group_by(cluster) %>%
dplyr::filter(avg_log2FC>1)
#cluster0 with threshold
cluster0.markers <- FindMarkers(pbmc, ident.1 = 0, logfc.threshold= 0.25, test.use= "roc", only.pos= TRUE)
cluster0.markers <- FindMarkers(pbmc, ident.1 = 0, logfc.threshold= 0.25, test.use= "roc", only.pos= TRUE)
#expression distribution across clusters with violin plot
VlnPlot(pbmc, features = c("MS4A1", "CD79A"))
#raw count plot
VlnPlot(pbmc, features = c("NKG7", "PF4"), slot = "counts", log = TRUE)
#multiple genes plot
FeaturePlot(pbmc, features = c("MS4A1", "GNLY", "CD3E", "CD14", "FCER1A", "FCG3A", "LYZ", "PPBP", "CD8A"))
pbmc.markers %>%
group_by(cluster) %>%
dplyr::filter(avg_log2FC>1) %>%
slice_head(n=10) %>%
ungroup() -> top10
DoHeatmap(pbmc, features = top10$gene)+ NoLegend()
pbmc.markers %>%
group_by(cluster) %>%
dplyr::filter(avg_log2FC>1) %>%
slice_head(n=3) %>%
ungroup() -> top3
DoHeatmap(pbmc, features = top3$gene)+ NoLegend()
#cluster ID for cell types
new.cluster.ids <- c("Naive CD4 T", "CD14+ Mono", "Memory CD4 T", "B", "CD8 T", "FCGR3A+ Mono",
"NK", "DC", "Platelet")
names(new.cluster.ids) <- levels(pbmc)
pbmc <- RenameIdents(pbmc, new.cluster.ids)
new.cluster.ids <- c("Naive CD4 T", "CD14+ Mono", "Memory CD4 T", "B", "CD8 T", "FCGR3A+ Mono",
"NK", "DC", "Platelet")
names(new.cluster.ids) <- levels(pbmc)
